# Supabase - get these from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Loco - translation management (server-side only, used in CI/CD workflow)
# Never prefix with VITE_ — this key must NOT be exposed to the browser
LOCO_API_KEY=your-loco-api-key
