# Supabase - get these from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Loco - translation management (server-side only, used in CI/CD workflow)
# Never prefix with VITE_ — this key must NOT be exposed to the browser
LOCO_API_KEY=your-loco-api-key

# EmailJS - email notifications on new contact messages (optional)
# Create a free account at emailjs.com, connect your Gmail, create a template
# with variables: {{from_name}}, {{from_email}}, {{message}}, {{to_email}}
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key
